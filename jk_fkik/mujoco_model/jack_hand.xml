<!--
  杰克灵巧手 MuJoCo MJCF 模型
  
  基于 fkik_solve 代码仓库的运动学参数构建
  所有几何体使用 MuJoCo 内置基元（无需外部 3D 模型文件）
  
  结构说明:
    - 拇指: 4-DOF 串联机构 (q1_Rx → q2_Rz → Ry_alpha1 → q3 → q4)
    - 四指 (食指/中指/环指/小指): 等效串联模型
      - MCP: q1(屈伸) + q2(外展) 两个旋转关节
      - PIP: q3 旋转关节
      - DIP: q4 旋转关节 (通过 equality/joint 耦合到 q3)
      - 串联链: PM(42.39mm) → MN(30mm) → NT(24.16mm)
  
  单位: 长度 m, 角度 rad
  
  作者: 基于上海钧舵杰克灵巧手运动学参数
-->
<mujoco model="jodell_jack_hand">
  
  <!-- ==================== 编译选项 ==================== -->
  <compiler angle="radian" eulerseq="xyz"/>
  
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicit"/>
  
  <!-- ==================== 默认参数 ==================== -->
  <default>
    <joint damping="0.01" armature="0.001"/>
    <geom rgba="0.8 0.75 0.65 1" friction="1.0 0.005 0.001"/>
    
    <!-- 手指连杆默认样式 -->
    <default class="finger_link">
      <geom type="capsule" rgba="0.7 0.7 0.72 1" size="0.003"/>
    </default>
    
    <!-- 拇指连杆默认样式 -->
    <default class="thumb_link">
      <geom type="capsule" rgba="0.75 0.72 0.68 1" size="0.0035"/>
    </default>
    
    <!-- 关节默认参数 -->
    <default class="finger_joint">
      <joint damping="0.005" armature="0.0005" limited="true"/>
    </default>
    
    <default class="thumb_joint">
      <joint damping="0.008" armature="0.0008" limited="true"/>
    </default>
    
    <!-- 指尖接触面 -->
    <default class="fingertip">
      <geom type="sphere" size="0.004" rgba="0.9 0.85 0.8 1"
            friction="2.0 0.01 0.005" condim="4"/>
    </default>
  </default>
  
  <!-- ==================== 资产 ==================== -->
  <asset>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.3 0.3 0.35" rgb2="0.35 0.35 0.4"/>
    <material name="grid_mat" texture="grid" texrepeat="8 8"/>
    <material name="palm_mat" rgba="0.65 0.62 0.58 1"/>
  </asset>
  
  <!-- ==================== 世界体 ==================== -->
  <worldbody>
    <!-- 地面 -->
    <geom name="floor" type="plane" size="0.5 0.5 0.01" 
          material="grid_mat" pos="0 0 -0.1"/>
    
    <!-- 光源 -->
    <light pos="0.3 0.3 0.5" dir="-0.3 -0.3 -0.5" diffuse="0.8 0.8 0.8"/>
    <light pos="-0.3 0.3 0.5" dir="0.3 -0.3 -0.5" diffuse="0.4 0.4 0.4"/>
    
    <!-- ==================== 支撑架 ==================== -->
    <geom name="stand_base" type="box" size="0.1 0.1 0.01" pos="0 0 0.01" rgba="0.3 0.3 0.3 1"/>
    <geom name="stand_pole" type="cylinder" size="0.015 0.1" pos="0 0 0.1" rgba="0.2 0.2 0.2 1"/>

    <!-- ==================== 手掌基座 ==================== -->
    <!-- 手掌竖立：手指朝上(+Z)，掌心朝前(+Y) -->
    <body name="palm" pos="0 0 0.2">
      <!-- 移除 freejoint，固定在支架上 -->
      <inertial pos="0 0 0" mass="0.15" 
                diaginertia="0.00005 0.00008 0.00003"/>
      <!-- 手掌几何体 -->
      <geom name="palm_body" type="box" size="0.045 0.012 0.04" 
            pos="0 0 0.02" rgba="0.65 0.62 0.58 1"/>
      <geom name="palm_top" type="box" size="0.04 0.010 0.008" 
            pos="0 0 0.065" rgba="0.65 0.62 0.58 1"/>
      
      <!-- ============================================================ -->
      <!--                    拇指 (Thumb) - 4 DOF                      -->
      <!-- ============================================================ -->
      <!--
        运动链: Rx(q1) · Rz(q2) · Ry(alpha1=-3.65°) 
              → OM(L1=23.56mm) → MN(L2=53.17mm, th3) → NT(L3=25.57mm, th3+th4)
        alpha1 = -3.65° = -0.0637 rad
        alpha2 =  8.22° =  0.1434 rad (q3 偏角)
        alpha3 = -16.72° = -0.2919 rad (q4 偏角)
      -->
      <body name="thumb_base" pos="-0.035 0.005 0.005" 
            euler="0 -1.5708 0">
        <inertial pos="0 0 0" mass="0.002" 
                  diaginertia="0.0000001 0.0000001 0.0000001"/>
        <!-- q1: 绕 X 轴旋转 (屈伸) -->
        <joint name="thumb_q1" class="thumb_joint" type="hinge" 
               axis="1 0 0" range="-1.6580 0" ref="0"/>
        
        <body name="thumb_q2_frame" pos="0 0 0" euler="0 0 3.14159265">
          <inertial pos="0 0 0" mass="0.002" 
                    diaginertia="0.0000001 0.0000001 0.0000001"/>
          <!-- q2: 绕 Z 轴旋转 (内收外展) -->
          <joint name="thumb_q2" class="thumb_joint" type="hinge" 
                 axis="0 0 1" range="-0.9599 0" ref="0"/>
          
          <!-- alpha1 固定偏角: Ry(-3.65°) -->
          <body name="thumb_link_OM" pos="0 0 0" euler="0 -0.0637 0">
            <inertial pos="0 0 0.01178" mass="0.008" 
                      diaginertia="0.000001 0.000001 0.0000002"/>
            <!-- OM 连杆: L1 = 23.56mm, 沿 z 轴 -->
            <geom name="thumb_OM" class="thumb_link"
                  fromto="0 0 0  0 0 0.02356"/>
            
            <!-- M 点 -->
            <body name="thumb_link_MN" pos="0 0 0.02356">
              <!-- q3: 含 alpha2=8.22° 偏角, 绕局部 Y 轴旋转 -->
              <!-- 实际角 th3 = alpha2 + q3, 通过 ref 偏移 -->
              <joint name="thumb_q3" class="thumb_joint" type="hinge"
                     axis="0 1 0" range="-1.5010 0" ref="-0.1434"/>
              <inertial pos="0 0 0.02658" mass="0.012" 
                        diaginertia="0.000003 0.000003 0.0000003"/>
              <!-- MN 连杆: L2 = 53.17mm -->
              <geom name="thumb_MN" class="thumb_link"
                    fromto="0 0 0  0 0 0.05317"/>
              
              <!-- N 点 -->
              <body name="thumb_link_NT" pos="0 0 0.05317">
                <!-- q4: 含 alpha3=-16.72° 偏角 -->
                <joint name="thumb_q4" class="thumb_joint" type="hinge"
                       axis="0 1 0" range="-1.2217 0" ref="0.2919"/>
                <inertial pos="0 0 0.01278" mass="0.006" 
                          diaginertia="0.0000008 0.0000008 0.0000001"/>
                <!-- NT 连杆: L3 = 25.57mm -->
                <geom name="thumb_NT" class="thumb_link"
                      fromto="0 0 0  0 0 0.02557"/>
                
                <!-- T 点 (指尖) -->
                <body name="thumb_tip" pos="0 0 0.02557">
                  <geom name="thumb_tip_geom" class="fingertip"/>
                  <site name="thumb_tip_site" pos="0 0 0" size="0.002"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
      
      <!-- ============================================================ -->
      <!--              食指 (Index) - 等效 3 DOF + 耦合                  -->
      <!-- ============================================================ -->
      <!--
        等效串联模型: q1(屈伸,Rx) + q2(外展,Ry) → PM → MN(q3) → NT(q4)
        PM = 42.39mm, MN = 30mm, NT = 24.16mm
        初始偏置: theta_init = -5.41° = -0.0944 rad
        theta3 = q3 + 5.41°, theta4 = q4 - 8.15°
        
        并联机构 (d1,d2→q1,q2) 通过控制层映射
      -->
      <body name="index_base" pos="-0.027 0 0.068" euler="-0.0944 0 0">
        <inertial pos="0 0 0" mass="0.002" 
                  diaginertia="0.0000001 0.0000001 0.0000001"/>
        <!-- q1: 屈伸 (绕 X 轴) -->
        <joint name="index_q1" class="finger_joint" type="hinge"
               axis="1 0 0" range="-1.5708 0.2618" ref="0"/>
        
        <body name="index_q2_frame" pos="0 0 0">
          <inertial pos="0 0 0" mass="0.002" 
                    diaginertia="0.0000001 0.0000001 0.0000001"/>
          <!-- q2: 外展 (绕 Y 轴) -->
          <joint name="index_q2" class="finger_joint" type="hinge"
                 axis="0 1 0" range="-0.35 0.35" ref="0"/>
          
          <!-- PM 连杆: 42.39mm 沿 z 轴 -->
          <body name="index_link_PM" pos="0 0 0">
            <inertial pos="0 0 0.02119" mass="0.010"
                      diaginertia="0.000002 0.000002 0.0000003"/>
            <geom name="index_PM" class="finger_link"
                  fromto="0 0 0  0 0 0.04239"/>
            
            <!-- M 点 -->
            <body name="index_link_MN" pos="0 0 0.04239">
              <!-- q3: PIP 关节 (绕 X 轴) -->
              <joint name="index_q3" class="finger_joint" type="hinge"
                     axis="1 0 0" range="-1.5708 0.2618" ref="0"/>
              <inertial pos="0 0 0.015" mass="0.006"
                        diaginertia="0.0000008 0.0000008 0.0000001"/>
              <geom name="index_MN" class="finger_link"
                    fromto="0 0 0  0 0 0.03"/>
              
              <!-- N 点 -->
              <body name="index_link_NT" pos="0 0 0.03">
                <!-- q4: DIP 关节 (耦合到 q3) -->
                <joint name="index_q4" class="finger_joint" type="hinge"
                       axis="1 0 0" range="-1.5708 0.2618" ref="0"/>
                <inertial pos="0 0 0.01208" mass="0.004"
                          diaginertia="0.0000004 0.0000004 0.00000005"/>
                <geom name="index_NT" class="finger_link"
                      fromto="0 0 0  0 0 0.02416"/>
                
                <!-- T 点 (指尖) -->
                <body name="index_tip" pos="0 0 0.02416">
                  <geom name="index_tip_geom" class="fingertip"/>
                  <site name="index_tip_site" pos="0 0 0" size="0.002"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
      
      <!-- ============================================================ -->
      <!--                      中指 (Middle)                            -->
      <!-- ============================================================ -->
      <body name="middle_base" pos="-0.009 0 0.072" euler="-0.0944 0 0">
        <inertial pos="0 0 0" mass="0.002" 
                  diaginertia="0.0000001 0.0000001 0.0000001"/>
        <joint name="middle_q1" class="finger_joint" type="hinge"
               axis="1 0 0" range="-1.5708 0.2618" ref="0"/>
        <body name="middle_q2_frame" pos="0 0 0">
          <inertial pos="0 0 0" mass="0.002" 
                    diaginertia="0.0000001 0.0000001 0.0000001"/>
          <joint name="middle_q2" class="finger_joint" type="hinge"
                 axis="0 1 0" range="-0.35 0.35" ref="0"/>
          <body name="middle_link_PM" pos="0 0 0">
            <inertial pos="0 0 0.02119" mass="0.010"
                      diaginertia="0.000002 0.000002 0.0000003"/>
            <geom name="middle_PM" class="finger_link"
                  fromto="0 0 0  0 0 0.04239"/>
            <body name="middle_link_MN" pos="0 0 0.04239">
              <joint name="middle_q3" class="finger_joint" type="hinge"
                     axis="1 0 0" range="-1.5708 0.2618" ref="0"/>
              <inertial pos="0 0 0.015" mass="0.006"
                        diaginertia="0.0000008 0.0000008 0.0000001"/>
              <geom name="middle_MN" class="finger_link"
                    fromto="0 0 0  0 0 0.03"/>
              <body name="middle_link_NT" pos="0 0 0.03">
                <joint name="middle_q4" class="finger_joint" type="hinge"
                       axis="1 0 0" range="-1.5708 0.2618" ref="0"/>
                <inertial pos="0 0 0.01208" mass="0.004"
                          diaginertia="0.0000004 0.0000004 0.00000005"/>
                <geom name="middle_NT" class="finger_link"
                      fromto="0 0 0  0 0 0.02416"/>
                <body name="middle_tip" pos="0 0 0.02416">
                  <geom name="middle_tip_geom" class="fingertip"/>
                  <site name="middle_tip_site" pos="0 0 0" size="0.002"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
      
      <!-- ============================================================ -->
      <!--                      环指 (Ring)                              -->
      <!-- ============================================================ -->
      <body name="ring_base" pos="0.009 0 0.074" euler="-0.0944 0 0">
        <inertial pos="0 0 0" mass="0.002" 
                  diaginertia="0.0000001 0.0000001 0.0000001"/>
        <joint name="ring_q1" class="finger_joint" type="hinge"
               axis="1 0 0" range="-1.5708 0.2618" ref="0"/>
        <body name="ring_q2_frame" pos="0 0 0">
          <inertial pos="0 0 0" mass="0.002" 
                    diaginertia="0.0000001 0.0000001 0.0000001"/>
          <joint name="ring_q2" class="finger_joint" type="hinge"
                 axis="0 1 0" range="-0.35 0.35" ref="0"/>
          <body name="ring_link_PM" pos="0 0 0">
            <inertial pos="0 0 0.02119" mass="0.010"
                      diaginertia="0.000002 0.000002 0.0000003"/>
            <geom name="ring_PM" class="finger_link"
                  fromto="0 0 0  0 0 0.04239"/>
            <body name="ring_link_MN" pos="0 0 0.04239">
              <joint name="ring_q3" class="finger_joint" type="hinge"
                     axis="1 0 0" range="-1.5708 0.2618" ref="0"/>
              <inertial pos="0 0 0.015" mass="0.006"
                        diaginertia="0.0000008 0.0000008 0.0000001"/>
              <geom name="ring_MN" class="finger_link"
                    fromto="0 0 0  0 0 0.03"/>
              <body name="ring_link_NT" pos="0 0 0.03">
                <joint name="ring_q4" class="finger_joint" type="hinge"
                       axis="1 0 0" range="-1.5708 0.2618" ref="0"/>
                <inertial pos="0 0 0.01208" mass="0.004"
                          diaginertia="0.0000004 0.0000004 0.00000005"/>
                <geom name="ring_NT" class="finger_link"
                      fromto="0 0 0  0 0 0.02416"/>
                <body name="ring_tip" pos="0 0 0.02416">
                  <geom name="ring_tip_geom" class="fingertip"/>
                  <site name="ring_tip_site" pos="0 0 0" size="0.002"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
      
      <!-- ============================================================ -->
      <!--                      小指 (Little)                            -->
      <!-- ============================================================ -->
      <body name="little_base" pos="0.027 0 0.072" euler="-0.0944 0 0">
        <inertial pos="0 0 0" mass="0.002" 
                  diaginertia="0.0000001 0.0000001 0.0000001"/>
        <joint name="little_q1" class="finger_joint" type="hinge"
               axis="1 0 0" range="-1.5708 0.2618" ref="0"/>
        <body name="little_q2_frame" pos="0 0 0">
          <inertial pos="0 0 0" mass="0.002" 
                    diaginertia="0.0000001 0.0000001 0.0000001"/>
          <joint name="little_q2" class="finger_joint" type="hinge"
                 axis="0 1 0" range="-0.35 0.35" ref="0"/>
          <body name="little_link_PM" pos="0 0 0">
            <inertial pos="0 0 0.02119" mass="0.010"
                      diaginertia="0.000002 0.000002 0.0000003"/>
            <geom name="little_PM" class="finger_link"
                  fromto="0 0 0  0 0 0.04239"/>
            <body name="little_link_MN" pos="0 0 0.04239">
              <joint name="little_q3" class="finger_joint" type="hinge"
                     axis="1 0 0" range="-1.5708 0.2618" ref="0"/>
              <inertial pos="0 0 0.015" mass="0.006"
                        diaginertia="0.0000008 0.0000008 0.0000001"/>
              <geom name="little_MN" class="finger_link"
                    fromto="0 0 0  0 0 0.03"/>
              <body name="little_link_NT" pos="0 0 0.03">
                <joint name="little_q4" class="finger_joint" type="hinge"
                       axis="1 0 0" range="-1.5708 0.2618" ref="0"/>
                <inertial pos="0 0 0.01208" mass="0.004"
                          diaginertia="0.0000004 0.0000004 0.00000005"/>
                <geom name="little_NT" class="finger_link"
                      fromto="0 0 0  0 0 0.02416"/>
                <body name="little_tip" pos="0 0 0.02416">
                  <geom name="little_tip_geom" class="fingertip"/>
                  <site name="little_tip_site" pos="0 0 0" size="0.002"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
      
    </body><!-- end palm -->
  </worldbody>
  
  <!-- ==================== 等式约束 ==================== -->
  <!--
    q3→q4 四连杆耦合 (多项式拟合)
    
    MuJoCo polycoef: q4 = a0 + a1*q3 + a2*q3^2 + a3*q3^3 + a4*q3^4
    
    基于 q3_to_q4() 函数在 [-90°,-9.48°] 范围的独立 4 阶拟合结果:
      a0 = -0.01462306
      a1 =  1.27106752
      a2 =  0.07657957
      a3 =  0.05314150
      a4 =  0.10674332
    最大误差: 0.2155° / RMS: 0.0512° (弧度域拟合)
    
    注: 之前使用的是 5 阶拟合的前 5 个系数(截断 a5)，导致大弯曲角度下
    误差高达 70°。已更正为独立 4 阶最优拟合。
    
    完整 5 阶拟合系数 (供参考，MuJoCo polycoef 仅支持 5 个系数):
      a0~a5: 0.00917 1.48499 0.73694 0.95578 0.66751 0.12919
      最大误差: 0.0555°
  -->
  <equality>
    <!-- 食指 q3-q4 耦合 -->
    <joint name="index_q3q4_coupling" joint1="index_q4" joint2="index_q3"
           polycoef="-0.01462 1.27107 0.07658 0.05314 0.10674"/>
    
    <!-- 中指 q3-q4 耦合 -->
    <joint name="middle_q3q4_coupling" joint1="middle_q4" joint2="middle_q3"
           polycoef="-0.01462 1.27107 0.07658 0.05314 0.10674"/>
    
    <!-- 环指 q3-q4 耦合 -->
    <joint name="ring_q3q4_coupling" joint1="ring_q4" joint2="ring_q3"
           polycoef="-0.01462 1.27107 0.07658 0.05314 0.10674"/>
    
    <!-- 小指 q3-q4 耦合 -->
    <joint name="little_q3q4_coupling" joint1="little_q4" joint2="little_q3"
           polycoef="-0.01462 1.27107 0.07658 0.05314 0.10674"/>
  </equality>
  
  <!-- ==================== 驱动器 ==================== -->
  <actuator>
    <!-- 拇指驱动 (4个关节直接力矩驱动) -->
    <position name="thumb_act_q1" joint="thumb_q1" kp="2.0" ctrlrange="-1.658 0"/>
    <position name="thumb_act_q2" joint="thumb_q2" kp="2.0" ctrlrange="-0.960 0"/>
    <position name="thumb_act_q3" joint="thumb_q3" kp="1.5" ctrlrange="-1.501 0"/>
    <position name="thumb_act_q4" joint="thumb_q4" kp="1.0" ctrlrange="-1.222 0"/>
    
    <!-- 食指驱动 (q1, q2 由并联机构映射; q3 直接驱动; q4 由耦合约束) -->
    <position name="index_act_q1" joint="index_q1" kp="2.0" ctrlrange="-1.571 0.262"/>
    <position name="index_act_q2" joint="index_q2" kp="1.5" ctrlrange="-0.35 0.35"/>
    <position name="index_act_q3" joint="index_q3" kp="1.5" ctrlrange="-1.571 0.262"/>
    
    <!-- 中指驱动 -->
    <position name="middle_act_q1" joint="middle_q1" kp="2.0" ctrlrange="-1.571 0.262"/>
    <position name="middle_act_q2" joint="middle_q2" kp="1.5" ctrlrange="-0.35 0.35"/>
    <position name="middle_act_q3" joint="middle_q3" kp="1.5" ctrlrange="-1.571 0.262"/>
    
    <!-- 环指驱动 -->
    <position name="ring_act_q1" joint="ring_q1" kp="2.0" ctrlrange="-1.571 0.262"/>
    <position name="ring_act_q2" joint="ring_q2" kp="1.5" ctrlrange="-0.35 0.35"/>
    <position name="ring_act_q3" joint="ring_q3" kp="1.5" ctrlrange="-1.571 0.262"/>
    
    <!-- 小指驱动 -->
    <position name="little_act_q1" joint="little_q1" kp="2.0" ctrlrange="-1.571 0.262"/>
    <position name="little_act_q2" joint="little_q2" kp="1.5" ctrlrange="-0.35 0.35"/>
    <position name="little_act_q3" joint="little_q3" kp="1.5" ctrlrange="-1.571 0.262"/>
  </actuator>
  
  <!-- ==================== 传感器 ==================== -->
  <sensor>
    <!-- 指尖位置传感器 -->
    <framepos name="thumb_tip_pos" objtype="site" objname="thumb_tip_site"/>
    <framepos name="index_tip_pos" objtype="site" objname="index_tip_site"/>
    <framepos name="middle_tip_pos" objtype="site" objname="middle_tip_site"/>
    <framepos name="ring_tip_pos" objtype="site" objname="ring_tip_site"/>
    <framepos name="little_tip_pos" objtype="site" objname="little_tip_site"/>
    
    <!-- 关节角度传感器 -->
    <jointpos name="thumb_q1_pos" joint="thumb_q1"/>
    <jointpos name="thumb_q2_pos" joint="thumb_q2"/>
    <jointpos name="thumb_q3_pos" joint="thumb_q3"/>
    <jointpos name="thumb_q4_pos" joint="thumb_q4"/>
    <jointpos name="index_q1_pos" joint="index_q1"/>
    <jointpos name="index_q2_pos" joint="index_q2"/>
    <jointpos name="index_q3_pos" joint="index_q3"/>
    <jointpos name="index_q4_pos" joint="index_q4"/>
  </sensor>
  
</mujoco>
