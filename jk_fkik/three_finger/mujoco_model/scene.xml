<!--
  抓取场景：三指手 + 地面 + 灯光 + 物体放置台 + 抓取目标

  通过 <include> 引入机器人本体模型 jack_hand_3f_robot.xml
  场景元素（地面、灯光、桌台、目标物体）在此文件定义
  修改场景不影响机器人模型，反之亦然
-->
<mujoco model="jodell_grasp_scene">

  <compiler angle="radian" eulerseq="xyz"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicit"/>

  <!-- 引入机器人本体 -->
  <include file="jack_hand_3f_robot.xml"/>

  <!-- ==================== 场景资产 ==================== -->
  <asset>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.3 0.3 0.35" rgb2="0.35 0.35 0.4"/>
    <material name="grid_mat" texture="grid" texrepeat="8 8"/>
  </asset>

  <!-- ==================== 场景物体 ==================== -->
  <worldbody>
    <!-- 地面 -->
    <geom name="floor" type="plane" size="0.5 0.5 0.01"
          material="grid_mat" pos="0 0 -0.1"/>

    <!-- 灯光 -->
    <light pos="0.3 0.3 0.5" dir="-0.3 -0.3 -0.5" diffuse="0.8 0.8 0.8"/>
    <light pos="-0.3 0.3 0.5" dir="0.3 -0.3 -0.5" diffuse="0.4 0.4 0.4"/>

    <!-- 物体放置台 -->
    <geom name="table_top" type="cylinder" size="0.025 0.005"
          pos="-0.02 0.08 0.245" rgba="0.45 0.45 0.5 1"
          friction="1.0 0.005 0.001"/>
    <geom name="table_leg" type="cylinder" size="0.006 0.12"
          pos="-0.02 0.08 0.12" rgba="0.35 0.35 0.4 1"/>

    <!-- 抓取目标物体 -->
    <body name="target_object" pos="-0.02 0.08 0.265">
      <freejoint name="obj_free"/>
      <inertial pos="0 0 0" mass="0.05"
                diaginertia="0.000005 0.000005 0.000005"/>
      <geom name="obj_geom" type="sphere" size="0.02" mass="0.05"
            rgba="0.9 0.2 0.2 1" friction="1.0 0.005 0.001"
            condim="4"/>
    </body>
  </worldbody>

</mujoco>
